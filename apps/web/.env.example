# ============================================================================
# Agentis Web — Environment Variables
# ============================================================================

# Hosted mode: controls whether the transcript upload UI is shown
# Set to "true" for internal/local use. Unset or "false" for hosted app.
# NEXT_PUBLIC_ENABLE_INTERNAL_TRANSCRIPT=true

# Local mode: enables filesystem discovery APIs (/api/local/*)
# Set to "true" when running via @agentis/local or local development.
# AGENTIS_LOCAL_MODE=true

# Client-side flag for local mode (enables auto-detected sessions UI).
# Must match AGENTIS_LOCAL_MODE.
# NEXT_PUBLIC_AGENTIS_LOCAL=true

# Override Claude projects path (default: ~/.claude/projects/)
# CLAUDE_PROJECTS_PATH=/custom/path/to/claude/projects
