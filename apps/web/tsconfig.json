{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "incremental": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./app/*"
      ],
      "@multiverse/shared": [
        "../../packages/shared/src"
      ],
      "@multiverse/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@multiverse/ingest": [
        "../../packages/ingest/src/index.ts"
      ],
      "@multiverse/ingest/*": [
        "../../packages/ingest/src/*"
      ],
      "@multiverse/ingest/browser": [
        "../../packages/ingest/src/browser/index.ts"
      ],
      "@multiverse/world-model": [
        "../../packages/world-model/src"
      ],
      "@multiverse/world-model/*": [
        "../../packages/world-model/src/*"
      ],
      "@multiverse/ui": [
        "../../packages/ui/src"
      ],
      "@multiverse/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@multiverse/engine": [
        "../../packages/engine/src"
      ],
      "@multiverse/engine/*": [
        "../../packages/engine/src/*"
      ]
    },
    "baseUrl": ".",
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": [
    "next-env.d.ts",
    "app",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/engine/src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
