{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@multiverse/shared": ["../../packages/shared/src"],
      "@multiverse/shared/*": ["../../packages/shared/src/*"],
      "@multiverse/ingest/browser": ["../../packages/ingest/src/browser/index.ts"],
      "@multiverse/world-model": ["../../packages/world-model/src"],
      "@multiverse/world-model/*": ["../../packages/world-model/src/*"],
      "@multiverse/ui": ["../../packages/ui/src"],
      "@multiverse/ui/*": ["../../packages/ui/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src"]
}
