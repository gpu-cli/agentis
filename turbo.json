{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["AGENTIS_STATIC_EXPORT", "AGENTIS_LOCAL_MODE", "NEXT_PUBLIC_AGENTIS_LOCAL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "static/**", "out/**", "tsconfig.tsbuildinfo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
